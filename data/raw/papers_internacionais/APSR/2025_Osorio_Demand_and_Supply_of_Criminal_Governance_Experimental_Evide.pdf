<img src="data:image/gif;base64,R0lGODlhAQABAIAAAMLCwgAAACH5BAAAAAAALAAAAAABAAEAAAICRAEAOw==" data-src="https://static.cambridge.org/binary/version/id/urn:cambridge.org:id:binary:20251018043725675-0848:S0003055425101251:S0003055425101251_inline5.png?pub-status=live" class="aop-lazy-load-image mathjax-alternative mathjax-alt-graphic mathjax-off" width="7" height="10" data-original-image="/binary/version/id/urn:cambridge.org:id:binary:20251018043725675-0848:S0003055425101251:S0003055425101251_inline5.png" data-zoomable="false">
