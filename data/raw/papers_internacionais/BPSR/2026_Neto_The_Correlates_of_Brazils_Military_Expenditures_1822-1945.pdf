<script type="text/javascript">
            function currentDate() {
            var today = new Date();
            var months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']
            today.setTime(today.getTime());
            return today.getDate() + " " + months[today.getMonth()] + " " + today.getFullYear();
            }
            var citation = 'Amorim, Octavio and Acácio, Igor. The Correlates of Brazil’s Military Expenditures, 1822-1945: The Politics of Defense Policy in a Non-Democratic Era. Brazilian Political Science Review [online]. 2026, v. 20, n. 1 [Accessed CURRENTDATE], e0004. Available from: &lt;https://doi.org/10.1590/1981-3821202600010004&gt;. Epub 20 Mar 2026. ISSN 1981-3821. https://doi.org/10.1590/1981-3821202600010004.'.replace('CURRENTDATE', currentDate());
            document.getElementById('citation').innerHTML = citation;
            document.getElementById('citationCut').value = citation.replace('&lt;', '<').replace('&gt;', ">");
        </script>
</div>

        
      
      
