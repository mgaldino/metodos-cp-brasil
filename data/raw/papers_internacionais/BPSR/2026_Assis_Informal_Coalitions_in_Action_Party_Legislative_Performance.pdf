<script type="text/javascript">
            function currentDate() {
            var today = new Date();
            var months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']
            today.setTime(today.getTime());
            return today.getDate() + " " + months[today.getMonth()] + " " + today.getFullYear();
            }
            var citation = 'Assis, Pedro Paulo de and Silva, Glauco Peres da. Informal Coalitions in Action: Party Legislative Performance in Brazilian Presidentialism. Brazilian Political Science Review [online]. 2026, v. 20, n. 1 [Accessed CURRENTDATE], e0001. Available from: &lt;https://doi.org/10.1590/1981-3821202600010001&gt;. Epub 13 Feb 2026. ISSN 1981-3821. https://doi.org/10.1590/1981-3821202600010001.'.replace('CURRENTDATE', currentDate());
            document.getElementById('citation').innerHTML = citation;
            document.getElementById('citationCut').value = citation.replace('&lt;', '<').replace('&gt;', ">");
        </script>
</div>

        
      
      
