                <col>
              </colgroup>
              <thead>
                <tr>
                  <th colspan="17" style="font-weight:normal" valign="bottom">Table 2 – Roll-call Votes by Type of Governability, 1995–2016</th>
                </tr>
                <tr>
                  <th align="left" colspan="2" rowspan="3" style="font-weight:normal" valign="bottom"> </th>
                  <th colspan="5" style="font-weight:normal" valign="bottom">Qualified Threshold</th>
                  <th colspan="5" style="font-weight:normal" valign="bottom">Absolute Threshold</th>
                  <th colspan="5" style="font-weight:normal" valign="bottom">Simple Threshold</th>
                </tr>
                <tr>
