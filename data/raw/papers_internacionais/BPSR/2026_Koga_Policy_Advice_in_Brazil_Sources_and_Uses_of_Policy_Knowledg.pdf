<input id="citationCut" type="text" value=""><a class="btn btn-secondary btn-sm scielo__btn-with-icon--left copyLink" data-clipboard-target="#citationCut"><span class="material-icons-outlined">link</span>copy</a>
</div>
</div></div></div>
<script type="text/javascript">
            function currentDate() {
            var today = new Date();
            var months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']
            today.setTime(today.getTime());
            return today.getDate() + " " + months[today.getMonth()] + " " + today.getFullYear();
            }
            var citation = 'Koga, Natália Massaco et al. Policy Advice in Brazil: Sources and Uses of Policy Knowledge in a Federal Presidential System. Brazilian Political Science Review [online]. 2026, v. 20, n. 1 [Accessed CURRENTDATE], e0005. Available from: &lt;https://doi.org/10.1590/1981-3821202600010005&gt;. Epub 20 Mar 2026. ISSN 1981-3821. https://doi.org/10.1590/1981-3821202600010005.'.replace('CURRENTDATE', currentDate());
            document.getElementById('citation').innerHTML = citation;
            document.getElementById('citationCut').value = citation.replace('&lt;', '<').replace('&gt;', ">");
        </script>
</div>

        
      
      
